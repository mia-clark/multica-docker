# ============================================================
# Multica 自托管 - 环境变量配置
# 复制为 .env 后按需修改（至少必须改 JWT_SECRET）
# ============================================================

# ---------- 必填 ----------
# JWT 签名密钥，请用强随机字符串（如：openssl rand -hex 32）
JWT_SECRET=change-me-to-a-strong-random-string

# ---------- 镜像选择（可选） ----------
# 默认使用精简版 server。若想要内置 Claude Code / Codex / Gemini CLI，
# 改为: BACKEND_IMAGE=ghcr.io/mia-clark/multica-server-full
BACKEND_IMAGE=ghcr.io/mia-clark/multica-server

# 镜像版本标签。默认 latest（每天由 GitHub Actions 自动更新）。
# 锁版本时可改为某个 commit 短 hash 或 tag，如 v0.2.13
MULTICA_TAG=latest

# ---------- 端口映射（可选） ----------
WEB_PORT=3000
BACKEND_PORT=8080

# ---------- 数据库（可选，默认即可用） ----------
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_DB=multica

# ---------- CORS（可选） ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Google OAuth（可选） ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- WebSocket（可选） ----------
# 浏览器直连后端 WS 的地址；若部署在域名后，改成 wss://your-domain
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ---------- 邮件（可选，用于注册/找回密码） ----------
RESEND_API_KEY=

# ---------- 对象存储（可选，用于用户上传文件） ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
CLOUDFRONT_URL=

# ============================================================
# Agent CLI 三方凭据（仅 server-full 镜像使用；留空则走交互式 login）
# ============================================================
# 认证方式任选其一：
#   A. 直连官方：只填 *_API_KEY（下方每家的第一行）
#   B. 走第三方反代/中转：填 *_API_KEY + *_BASE_URL（详见下方说明）
#   C. 什么都不填，启动后进容器 `docker compose exec backend <cli> login`
#      凭据存到挂载的 volume，重启不丢

# ---------- Claude Code (Anthropic) ----------
# 官方直连：只填 ANTHROPIC_API_KEY
# 反代/中转：留空 API_KEY，填 AUTH_TOKEN + BASE_URL（多数反代用 Bearer Token 方式）
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
# 可选：指定默认模型（如 claude-sonnet-4-6 / claude-opus-4-7）
ANTHROPIC_MODEL=

# ---------- Codex (OpenAI) ----------
# 官方直连：只填 OPENAI_API_KEY
# 反代/中转：填 OPENAI_API_KEY + OPENAI_BASE_URL
#   容器启动时会自动生成 ~/.codex/config.toml，
#   把 provider 切到你的自定义 endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 可选：默认模型（如 gpt-4o / gpt-5）；不填则用 gpt-4o-mini
OPENAI_MODEL=
# 可选：wire_api 协议，chat（兼容绝大多数反代）或 responses（OpenAI 官方新协议）
# 不填默认 chat
CODEX_WIRE_API=
# 可选：自定义 provider 名字（仅影响 config.toml 可读性）
CODEX_PROVIDER_NAME=

# ---------- Gemini (Google) ----------
# ⚠️ 官方 CLI 没有"自定义 endpoint"环境变量，三种模式三选一：
#   模式 1（AI Studio，最简单）：填 GEMINI_API_KEY
#   模式 2（Vertex API Key）   ：填 GOOGLE_API_KEY + GOOGLE_GENAI_USE_VERTEXAI=true
#   模式 3（Vertex ADC 企业）  ：留空所有 KEY，外部挂载 ADC 凭据
#                                + GOOGLE_GENAI_USE_VERTEXAI=true
#                                + GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION
# 若要走第三方中转，请使用 Vertex 兼容的反代 + 模式 2
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
