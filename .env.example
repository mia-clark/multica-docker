# ============================================================
# Multica 自托管 - 环境变量配置
# 复制为 .env 后按需修改（至少必须改 JWT_SECRET）
# ============================================================

# ---------- 必填 ----------
# JWT 签名密钥，请用强随机字符串（如：openssl rand -hex 32）
JWT_SECRET=change-me-to-a-strong-random-string

# ---------- 镜像选择（可选） ----------
# 默认使用精简版 server。若想要内置 Claude Code / Codex / Gemini CLI，
# 改为: BACKEND_IMAGE=ghcr.io/mia-clark/multica-server-full
BACKEND_IMAGE=ghcr.io/mia-clark/multica-server

# 镜像版本标签。默认 latest（每天由 GitHub Actions 自动更新）。
# 锁版本时可改为某个 commit 短 hash 或 tag，如 v0.2.13
MULTICA_TAG=latest

# ---------- 端口映射（可选） ----------
WEB_PORT=3000
BACKEND_PORT=8080

# ---------- 数据库（可选，默认即可用） ----------
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_DB=multica

# ---------- CORS（可选） ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Google OAuth（可选） ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- WebSocket（可选） ----------
# 浏览器直连后端 WS 的地址；若部署在域名后，改成 wss://your-domain
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ---------- 邮件（可选，用于注册/找回密码） ----------
RESEND_API_KEY=

# ---------- 对象存储（可选，用于用户上传文件） ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
CLOUDFRONT_URL=

# ---------- Agent CLI API Keys（可选，仅 server-full 镜像使用） ----------
# 两种认证方式任选其一：
#   A. 在这里填 API Key，容器启动即可用
#   B. 留空，容器启动后进去交互式登录：
#        docker compose exec backend claude login
#        docker compose exec backend codex login
#        docker compose exec backend gemini   # 首次运行引导
#      凭据会存到挂载的 volume，重启不丢
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
