# ============================================================
# Multica 自托管 - 环境变量配置（最小模板）
# 复制为 .env 后按需修改（至少必须改 JWT_SECRET）
# ============================================================
#
# 架构：server（控制面）+ runtime（数据面，跑 agent CLI）+ web
# 首选完整配置（含第三方反代占位符）请用 .env.example.full
# ============================================================

# ---------- 必填 ----------
# JWT 签名密钥，请用强随机字符串（如：openssl rand -hex 32）
JWT_SECRET=f7b7e3380117336cb3393fa727ca44b9aee1abb098fa1850ab222e4db54a27b0

# ---------- 镜像选择（可选） ----------
# server = 控制面（Go 后端，精简）
# runtime = 数据面（multica daemon + claude/codex/gemini）
SERVER_IMAGE=ghcr.io/mia-clark/multica-server
RUNTIME_IMAGE=ghcr.io/mia-clark/multica-runtime

# 镜像版本标签。默认 latest（每天由 GitHub Actions 自动更新）。
# 锁版本时可改为某个 commit 短 hash 或 tag，如 v0.2.13
MULTICA_TAG=latest

# ---------- 端口映射（可选） ----------
WEB_PORT=3000
BACKEND_PORT=8080

# ---------- 数据库（可选，默认即可用） ----------
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_DB=multica

# ---------- CORS（可选） ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Google OAuth（可选） ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- WebSocket（可选） ----------
# 浏览器直连后端 WS 的地址；若部署在域名后，改成 wss://your-domain
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ---------- 邮件（可选，用于注册/找回密码） ----------
RESEND_API_KEY=

# ---------- 对象存储（可选，用于用户上传文件） ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
CLOUDFRONT_URL=

# ============================================================
# Runtime 接入 server（runtime 服务需要；server 不需要）
# ============================================================
# 容器间默认走 http://server:8080；对外部署时改成外网可达地址
MULTICA_SERVER_URL=http://server:8080
MULTICA_APP_URL=http://localhost:3000

# Personal Access Token：在 Multica Web UI 生成后填到这里，runtime 首次启动
# 会自动免交互登录。留空则需：docker compose exec runtime multica login
MULTICA_TOKEN=

# 可选：daemon 显示名 / 并发
MULTICA_DAEMON_DEVICE_NAME=
MULTICA_AGENT_RUNTIME_NAME=
MULTICA_DAEMON_MAX_CONCURRENT_TASKS=

# ============================================================
# Agent CLI 三方凭据（runtime 专属；留空可通过交互式 login 走订阅登录态）
# 详细说明见 .env.example.full
# ============================================================
# Claude Code
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# Codex (OpenAI)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
CODEX_WIRE_API=
CODEX_PROVIDER_NAME=

# Gemini (Google)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
