# syntax=docker/dockerfile:1.6
#
# Multica Server Full — 在官方 server 镜像基础上叠加 Claude Code / Codex / Gemini 三大 Agent CLI
#
# 对比：
#   multica-server       = Go 后端（精简）
#   multica-server-full  = Go 后端 + Node 22 + claude/codex/gemini 三大 CLI
#
# 启动行为与 multica-server 100% 一致（同一个 ENTRYPOINT / 同一个端口 8080）
# 额外用法：
#   docker compose exec multica-backend claude
#   docker compose exec multica-backend codex
#   docker compose exec multica-backend gemini
#   docker compose exec multica-backend multica daemon start --foreground

ARG MULTICA_SERVER_IMAGE=ghcr.io/mia-clark/multica-server:latest

FROM ${MULTICA_SERVER_IMAGE}

USER root

# 一次性装齐：
#   - nodejs + npm：Alpine 3.21 仓库即带 Node 22.x LTS，apk 会自动拉齐 libstdc++ 等运行时依赖
#   - bash / git / curl / openssh-client：agent 常用交互环境
#   - jq / ripgrep：Claude Code 等默认调用的工具
RUN apk add --no-cache \
        nodejs \
        npm \
        bash \
        git \
        curl \
        openssh-client \
        jq \
        ripgrep

# 硬校验 Node 版本 ≥ 20，避免某些发行版降级
RUN node -v | awk -F. '{ v=substr($1,2)+0; if (v<20) { print "Node too old: "$0; exit 1 } else { print "Node "$0" OK" } }'

# 把上游放在 /app 下的 multica / migrate 二进制暴露到 PATH
# （上游 Dockerfile 只负责 entrypoint.sh 内部调用，没做链接）
RUN ln -sf /app/multica /usr/local/bin/multica \
 && ln -sf /app/migrate /usr/local/bin/migrate

# 三大 Agent CLI（全局安装）
RUN npm install -g --no-audit --no-fund \
        @anthropic-ai/claude-code \
        @openai/codex \
        @google/gemini-cli \
 && npm cache clean --force

# 构建期强校验：任何一个 CLI 装坏立刻失败，避免推送不可用的镜像
RUN set -eux; \
    node -v; \
    npm -v; \
    claude --version; \
    codex --version; \
    gemini --version; \
    multica --version

# Agent 启动前置脚本：把 compose 灌进来的 OPENAI_BASE_URL / GEMINI_API_KEY 等
# 翻译成各 CLI 实际需要的配置文件（尤其是 Codex 必须写 config.toml），
# 让三家 CLI 在容器启动后无需手动 login 即可开箱即用。
COPY scripts/agents-init.sh /usr/local/bin/multica-agents-init.sh
RUN chmod +x /usr/local/bin/multica-agents-init.sh

# 包装上游 entrypoint：先跑初始化，再 exec 原 /app/entrypoint.sh
# WORKDIR=/app、EXPOSE=8080 等保持继承不变
ENTRYPOINT ["/usr/local/bin/multica-agents-init.sh"]
