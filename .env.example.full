# ============================================================
# Multica 自托管 · 首选配置模板（全能版 + 第三方反代）
#
# 适用场景：
#   - 想在后端容器里直接跑 claude / codex / gemini（不自己跑宿主机 daemon）
#   - 三家都走第三方统一网关 / 自建中转（国内常见）
#   - 想一次性配完、`docker compose up -d` 即开箱可用
#
# 使用：
#   cp .env.example.full .env
#   替换下方所有 `your-xxx` / `change-me` 占位符为真实值
#   docker compose up -d
#
# 如果你打算走官方直连、或只想要精简版，改用 .env.example
# ============================================================

# ---------- 必填 ----------
# openssl rand -hex 32  /  Windows PS: -join ((1..64)|%{'{0:x}' -f (Get-Random -Max 16)})
JWT_SECRET=f7b7e3380117336cb3393fa727ca44b9aee1abb098fa1850ab222e4db54a27b0

# ---------- 镜像选择 ----------
BACKEND_IMAGE=ghcr.io/mia-clark/multica-server-full
MULTICA_TAG=latest

# ---------- 端口映射 ----------
WEB_PORT=3000
BACKEND_PORT=8080

# ---------- 数据库（默认即可用） ----------
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_DB=multica

# ---------- CORS / WebSocket ----------
# 部署到域名后，CORS 改成 https://your-domain，WS 改成 wss://your-domain
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ============================================================
# Agent CLI 三方凭证（首选：走第三方反代）
# ============================================================

# ---------- Claude Code（反代 + Bearer Token） ----------
# 多数第三方 Claude 反代使用 Bearer Token 鉴权，填 AUTH_TOKEN 不填 API_KEY
ANTHROPIC_BASE_URL=https://your-proxy.example.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-your-proxy-token
ANTHROPIC_MODEL=claude-sonnet-4-7
# 如果反代是 Anthropic 兼容协议、要求 x-api-key 鉴权，改填：
# ANTHROPIC_API_KEY=sk-your-proxy-key

# ---------- Codex（反代 + OpenAI 兼容 API） ----------
# 容器启动时会自动生成 ~/.codex/config.toml，把 provider 切到你的 endpoint
OPENAI_BASE_URL=https://your-proxy.example.com/v1
OPENAI_API_KEY=sk-your-proxy-token
OPENAI_MODEL=gpt-5.4
# wire_api: chat（兼容绝大多数反代）/ responses（OpenAI 官方新协议）
CODEX_WIRE_API=chat

# ---------- Gemini（官方 CLI 无自定义 endpoint，用 Vertex 兼容反代） ----------
# 模式一：Gemini API key（AI Studio 直连 / 少数兼容此协议的反代）
# GEMINI_API_KEY=your-gemini-key
#
# 模式二（推荐走中转）：Vertex 兼容反代
GOOGLE_API_KEY=your-vertex-key
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================
# 以下均为可选字段，不用可全部留空；完整注释见 .env.example
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
RESEND_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
CLOUDFRONT_URL=
