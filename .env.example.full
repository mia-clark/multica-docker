# ============================================================
# Multica 自托管 · 首选完整配置模板
#
# 架构：server（控制面）+ runtime（数据面，跑 agent）+ web（前端）
# 本模板适用于：
#   - 容器化部署整个栈
#   - runtime 走第三方反代 / 中转（国内常见）
#   - 希望 `docker compose up -d` 一次性起来
#
# 使用步骤：
#   1. cp .env.example.full .env
#   2. 替换下方所有 `your-xxx` / `change-me` 占位符
#   3. 在 Multica Web UI 生成 Personal Access Token (PAT)，填 MULTICA_TOKEN
#   4. docker compose up -d
#   5. （可选）docker compose up -d --scale runtime=3  横向扩多 worker
# ============================================================

# ---------- 必填 ----------
# openssl rand -hex 32  /  Windows PS: -join ((1..64)|%{'{0:x}' -f (Get-Random -Max 16)})
JWT_SECRET=f7b7e3380117336cb3393fa727ca44b9aee1abb098fa1850ab222e4db54a27b0

# ---------- 镜像 ----------
SERVER_IMAGE=ghcr.io/mia-clark/multica-server
RUNTIME_IMAGE=ghcr.io/mia-clark/multica-runtime
MULTICA_TAG=latest

# ---------- 端口映射 ----------
WEB_PORT=3000
BACKEND_PORT=8080

# ---------- 数据库（默认即可用） ----------
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_DB=multica

# ---------- CORS / WebSocket ----------
# 部署到域名后，CORS 改成 https://your-domain，WS 改成 wss://your-domain
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ============================================================
# Runtime 接入自建 server（data plane ↔ control plane）
# ============================================================
# 默认容器间网络地址；若 runtime 部署在别的主机上，改成外网可达地址：
#   MULTICA_SERVER_URL=https://multica.your-domain.com
MULTICA_SERVER_URL=http://server:8080
MULTICA_APP_URL=http://localhost:3000

# Personal Access Token：Web UI → Settings → Personal Access Tokens 生成。
# 首次启动 runtime 容器会用它免交互登录，token 存到 multica_config volume 后
# 即使此变量被改/清空也不影响后续启动（重启不用重新登录）。
MULTICA_TOKEN=mul_pat_your-personal-access-token

# 可选：daemon 显示名（Web UI 的 Runtimes 列表里能看到）
MULTICA_DAEMON_DEVICE_NAME=docker-runtime
MULTICA_AGENT_RUNTIME_NAME=docker-runtime
# 可选：单个 runtime 最大并发任务
MULTICA_DAEMON_MAX_CONCURRENT_TASKS=3

# ============================================================
# Agent CLI 三方凭证（runtime 专属）
# ============================================================

# ---------- Claude Code（反代 + Bearer Token） ----------
# 多数第三方 Claude 反代用 Bearer Token 鉴权，填 AUTH_TOKEN 不填 API_KEY
ANTHROPIC_BASE_URL=https://your-proxy.example.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-your-proxy-token
ANTHROPIC_MODEL=claude-sonnet-4-6
# 如果反代是 Anthropic 兼容协议且要求 x-api-key 鉴权，改填：
# ANTHROPIC_API_KEY=sk-your-proxy-key

# ---------- Codex（反代 + OpenAI 兼容 API） ----------
# 容器启动时会自动生成 ~/.codex/config.toml，把 provider 切到你的 endpoint
OPENAI_BASE_URL=https://your-proxy.example.com/v1
OPENAI_API_KEY=sk-your-proxy-token
OPENAI_MODEL=gpt-4o
# wire_api: chat（兼容绝大多数反代）/ responses（OpenAI 官方新协议）
CODEX_WIRE_API=chat

# ---------- Gemini（官方 CLI 无自定义 endpoint，用 Vertex 兼容反代） ----------
# 模式一：Gemini API key（AI Studio 直连 / 少数兼容此协议的反代）
# GEMINI_API_KEY=your-gemini-key
#
# 模式二（推荐走中转）：Vertex 兼容反代
GOOGLE_API_KEY=your-vertex-key
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================
# 以下为可选字段，不用可全部留空；完整注释见 .env.example
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
RESEND_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
CLOUDFRONT_URL=
